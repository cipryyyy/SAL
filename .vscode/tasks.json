{
    "version": "2.0.0",
    "osx": {
        "options": {
            "shell": {
                "executable": "/bin/zsh",
                "args": ["-c"]
            }
        }
    },
    "tasks": [
        {
            "type": "shell",
            "label": "Compile project",
            "command": "rm -rf build && mkdir build && cd build && cmake -DCMAKE_TOOLCHAIN_FILE=../arm-none-eabi-toolchain.cmake .. && cmake --build .",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "build"
        },
        {
            "type": "shell",
            "label": "Flash project",
            "command": "STM32_Programmer_CLI",
            "args": [
                "--connect",
                "port=swd",
                "mode=UR",
                "reset=HwRst",
                "--download",
                "${workspaceFolder}/build/main.hex",
                "-hardRst",
                "-rst",
                "--start"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Compile + Flash",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Compile project",
                "Flash project"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
}